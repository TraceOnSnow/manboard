{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "启动 Manboard（前后端）",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/start-manboard.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "启动 Dashboard（并打开浏览器）",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/start-dashboard.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
