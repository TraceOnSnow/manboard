{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "启动 API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/core",
      "python": "${workspaceFolder}/core/.venv/bin/python",
      "env": {
        "MANBOARD_DATA_FILE": "${workspaceFolder}/data/threads.json"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "启动 Dashboard（并打开浏览器）",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "localhost"],
      "cwd": "${workspaceFolder}/dashboard",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\s+Local:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ],
  "compounds": [
    {
      "name": "启动 Manboard（前后端）",
      "configurations": ["启动 API", "启动 Dashboard（并打开浏览器）"],
      "stopAll": true
    }
  ]
}
