{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "启动 Manboard（前后端）",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/core",
      "python": "${workspaceFolder}/core/.venv/bin/python",
      "env": {
        "MANBOARD_DATA_FILE": "${workspaceFolder}/data/threads.json"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "serverReadyAction": {
        "action": "startDebugging",
        "pattern": "Uvicorn running on (https?://\\S+)",
        "name": "启动 Dashboard（并打开浏览器）"
      }
    },
    {
      "name": "启动 Dashboard（并打开浏览器）",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--host",
        "localhost"
      ],
      "cwd": "${workspaceFolder}/dashboard",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\s+Local:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ]
}
